@{
    ViewData["Title"] = "About Page";
}

@{
    Layout = "~/Views/_Layout.cshtml";
}

<div class="container">
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <h1 class="display-4">Welcome to AmetCoin</h1>
            <p class="lead">Revolutionizing cryptocurrency with cutting-edge blockchain technology and innovative solutions.</p>
            <div class="hero-buttons">
                <button class="btn btn-primary">Learn More</button>
                <button class="btn btn-secondary">Get Started</button>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
        <h2 class="section-title">Key Features</h2>
        <div class="features-grid">
            <div class="feature-card">
                <h3>Secure Transactions</h3>
                <p>Bank-level security for all your transactions with advanced encryption protocols.</p>
            </div>
            <div class="feature-card">
                <h3>Fast Processing</h3>
                <p>Lightning-fast transaction speeds with minimal confirmation times.</p>
            </div>
            <div class="feature-card">
                <h3>Global Accessibility</h3>
                <p>Access your cryptocurrency from anywhere in the world with our decentralized network.</p>
            </div>
        </div>
    </section>

    <!-- Technology Section -->
    <section class="technology-section">
        <h2 class="section-title">Blockchain Technology</h2>
        <div class="technology-content">
            <p>AmetCoin leverages the latest blockchain innovations to provide a secure, transparent, and efficient platform for digital currency transactions.</p>
            <div class="technology-details">
                <h3>Consensus Mechanism</h3>
                <p>Our proprietary proof-of-stake algorithm ensures energy efficiency while maintaining network security.</p>

                <h3>Scalability Solutions</h3>
                <p>Advanced sharding techniques allow us to process thousands of transactions per second.</p>

                <h3>Smart Contracts</h3>
                <p>Execute programmable contracts without intermediaries, reducing costs and increasing transparency.</p>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="team-section">
        <h2 class="section-title">Our Leadership Team</h2>
        <div class="team-grid">
            <div class="team-member">
                <div class="member-image"></div>
                <h3>John Smith</h3>
                <p class="role">CEO & Founder</p>
                <p>Blockchain vision with over 15 years of experience in financial technology.</p>
            </div>
            <div class="team-member">
                <div class="member-image"></div>
                <h3>Sarah Johnson</h3>
                <p class="role">CTO</p>
                <p>Expert in distributed systems and cryptographic protocols.</p>
            </div>
            <div class="team-member">
                <div class="member-image"></div>
                <h3>Michael Chen</h3>
                <p class="role">Lead Developer</p>
                <p>Full-stack developer specializing in blockchain applications.</p>
            </div>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="statistics-section">
        <h2 class="section-title">Our Achievements</h2>
        <div class="features-grid">
            <div class="feature-card">
                <h3 class="counter" data-target="1000000">0</h3>
                <p>Transactions Processed</p>
            </div>
            <div class="feature-card">
                <h3 class="counter" data-target="50000">0</h3>
                <p>Active Users</p>
            </div>
            <div class="feature-card">
                <h3 class="counter" data-target="25">0</h3>
                <p>Global Partnerships</p>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="testimonials-section">
        <h2 class="section-title">What Our Users Say</h2>
        <div class="testimonials-carousel">
            <div class="testimonial-slide active">
                <p>"AmetCoin has completely transformed how I manage my digital assets. The security and speed are unmatched."</p>
                <p>- Alex Johnson, Blockchain Enthusiast</p>
            </div>
            <div class="testimonial-slide">
                <p>"The intuitive interface makes cryptocurrency accessible to everyone, not just tech experts."</p>
                <p>- Maria Rodriguez, Investor</p>
            </div>
            <div class="testimonial-slide">
                <p>"Implementation of smart contracts has reduced transaction costs by 70% compared to traditional methods."</p>
                <p>- David Kim, Financial Analyst</p>
            </div>
            <div class="carousel-nav">
                <button class="carousel-btn carousel-prev">Previous</button>
                <button class="carousel-btn carousel-next">Next</button>
            </div>
        </div>
    </section>

    <!-- Market Price Section -->
    <section class="market-section">
        <h2 class="section-title">Live Market Price</h2>
        <div class="market-price-display">
            <p>Current Price: <span id="live-price">0.00000001</span> BTC</p>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-container">
            <div class="faq-item">
                <h3 class="faq-question">How do I get started with AmetCoin?</h3>
                <div class="faq-answer">
                    <p>To start using AmetCoin, download our wallet application from our website and create an account. You can then purchase AmetCoin tokens through our exchange partners or via direct purchase.</p>
                </div>
            </div>
            <div class="faq-item">
                <h3 class="faq-question">Is AmetCoin secure?</h3>
                <div class="faq-answer">
                    <p>Yes, AmetCoin employs industry-leading security measures including multi-signature wallets, cold storage for assets, and regular security audits to protect your investments.</p>
                </div>
            </div>
            <div class="faq-item">
                <h3 class="faq-question">What makes AmetCoin different from other cryptocurrencies?</h3>
                <div class="faq-answer">
                    <p>AmetCoin combines advanced blockchain technology with user-friendly interfaces, energy-efficient consensus mechanisms, and a strong focus on privacy and scalability.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form Section -->
    <section class="contact-section">
        <h2 class="section-title">Contact Us</h2>
        <form id="contact-form" class="contact-form">
            <div class="form-group">
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="name" class="form-control" required>
                <span id="name-error" class="error-message"></span>
            </div>
            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" class="form-control" required>
                <span id="email-error" class="error-message"></span>
            </div>
            <div class="form-group">
                <label for="message" class="form-label">Message</label>
                <textarea id="message" name="message" class="form-control" rows="5" required></textarea>
                <span id="message-error" class="error-message"></span>
            </div>
            <button type="submit" class="submit-btn">Send Message</button>
        </form>
    </section>
</div>

@section Scripts {
    <script src="~/js/interactive.js" asp-append-version="true"></script>
}