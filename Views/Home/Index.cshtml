@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://docs.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
    
    <!-- Design System Demo -->
    <div class="card">
        <div class="card-header">AmetCoin Design System Demo</div>
        <div class="card-body">
            <p>This demonstrates the components from our design system:</p>
            
            <button class="btn btn-primary">Primary Button</button>
            <button class="btn btn-secondary">Secondary Button</button>
            <button class="btn btn-outline">Outline Button</button>
            
            <div class="alert alert-success">
                This is a success alert using the design system!
            </div>
            
            <div class="alert alert-warning">
                This is a warning alert using the design system!
            </div>
            
            <div class="alert alert-danger">
                This is a danger alert using the design system!
            </div>
        </div>
    </div>
</div>